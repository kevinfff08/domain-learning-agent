# ============================================================
# LLM Mode: choose how to connect to Anthropic API
# ============================================================
# "api-key"      → Direct API call with ANTHROPIC_API_KEY (default)
# "setup-token"  → Route through CLIProxyAPI at localhost:8317
#                   (uses Claude subscription OAuth token, no API key needed)
LLM_MODE=api-key

# Required for api-key mode (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# CLIProxyAPI proxy address (only used in setup-token mode)
LLM_PROXY_URL=http://localhost:8317

# Optional: Higher rate limits for paper search
SEMANTIC_SCHOLAR_API_KEY=

# Optional: GitHub repository quality metrics
GITHUB_TOKEN=

# Optional: Override default LLM model
LLM_MODEL=claude-sonnet-4.6

# Backend server config
API_HOST=127.0.0.1
API_PORT=8000
