# ============================================================
# LLM Provider/Mode: choose vendor and connection style
# ============================================================
# "api-key"      → Direct API call with provider-specific API key (default)
# "setup-token"  → Route through CLIProxyAPI at localhost:8317
#                   (uses Claude subscription OAuth token, no API key needed)
LLM_MODE=api-key

# Optional provider override:
#   anthropic = Claude models
#   openai    = OpenAI models
#   deepseek  = DeepSeek models (official api-key mode only)
#   unset     = auto-detect from LLM_MODEL
LLM_PROVIDER=anthropic

# Required for Anthropic api-key mode (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required for OpenAI api-key mode (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# Required for DeepSeek api-key mode (get from https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...

# Optional OpenAI-compatible base URL in api-key mode
# OPENAI_BASE_URL=

# Optional DeepSeek-compatible base URL in api-key mode
# Defaults to https://api.deepseek.com/v1
# DEEPSEEK_BASE_URL=

# CLIProxyAPI proxy address (used in setup-token mode)
# For OpenAI provider, /v1 will be appended automatically if needed
LLM_PROXY_URL=http://localhost:8317

# Optional: Higher rate limits for paper search
SEMANTIC_SCHOLAR_API_KEY=

# Optional: GitHub repository quality metrics
GITHUB_TOKEN=

# Optional: Tavily web search for outline generation (get from https://tavily.com)
TAVILY_API_KEY=

# Optional: Override default LLM model
# Anthropic examples: claude-sonnet-4-20250514
# OpenAI examples: gpt-4.1, gpt-4o, gpt-5
# DeepSeek examples: deepseek-v4-flash, deepseek-v4-pro
LLM_MODEL=claude-sonnet-4-20250514

# Optional: Override max output tokens (project defaults stay conservative even if
# the provider supports much larger context/output windows, e.g. DeepSeek V4)
# LLM_MAX_TOKENS=

# Optional: Max auto-continuation attempts when output is truncated (default: 3)
# LLM_MAX_CONTINUATIONS=3

# Optional: Disable accuracy verification step (default: true)
# Set to false to skip citation/math/consistency checks during chapter generation
# VERIFICATION_ENABLED=true

# Optional: Use a different (cheaper) model for verification checks
# If not set, uses the same model as LLM_MODEL
# VERIFICATION_MODEL=claude-sonnet-4-20250514

# Backend server config
API_HOST=127.0.0.1
API_PORT=8000
